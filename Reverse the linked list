#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>
int n,top=-1;
struct Node{
    int data;
    struct Node* next;
};

struct Node* head = NULL;

struct Node* createnode(int data){
    struct Node* temp = (struct Node*) malloc(sizeof(struct Node));
    temp->data = data;
    temp->next = NULL;
    return temp;
}

void InsertAtEnd(int data){
    struct Node* newnode = createnode(data);
    if(head==NULL){
        head = newnode;
    }
    else{
        struct Node* temp = head;
        while(temp->next!=NULL){
            temp = temp->next;
        }
        temp->next = newnode;
    }
}

void deletefromend(){
    if(head->next==NULL){
        head = NULL;
    }
    else{
        struct Node* temp = head;
        while(temp->next->next!=NULL){
            temp = temp->next;
        }
        temp->next = NULL;
    }
}

void push(int stack[],int x){
    stack[++top] = x;    
}

int pop(int stack[]){
    return stack[top--];
}

void reverselinkedlist(int n){
    int stack[n];
    struct Node* temp = head;
    while(temp!=NULL){
        push(stack,temp->data);
        temp = temp->next;
    }
    temp = head;
    while(temp!=NULL){
        temp->data = pop(stack);
        temp = temp->next;
    }
}

void show(){
    struct Node* temp = head;
    while(temp!=NULL){
        printf("%d ",temp->data);
        temp = temp->next;
    }
}

int main() {
    int val;
    scanf("%d",&n);
    for(int i=0;i<n;i++){
        scanf("%d",&val);
        InsertAtEnd(val);
    }
    reverselinkedlist(n);
    show();
    return 0;
}
