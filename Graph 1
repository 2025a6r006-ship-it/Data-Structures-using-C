#include<stdio.h>
#include<stdlib.h>
#define max 100
int graph[max][max];
int n;
void insert(int u, int v){
    graph[u][v] = 1;
    graph[v][u] = 1; //only for undirected graph
}

void bfs(int start){
    int queue[max],front=-1,rear=-1;
    int visited[n];
    for(int i=0;i<n;i++){
        visited[i]=0;
    }
    queue[++rear]=start;
    visited[start]=1;
    front++;
    printf("BFS Traversal: ");
    while(front<=rear){
        int v = queue[front++];
        printf("%d ",v);
        for(int i=0;i<n;i++){
            if(graph[v][i]==1 && visited[i]==0){
                queue[++rear]=i;
                visited[i]=1;
            }
        }
    }
    printf("\n");
}

void dfs(int start){
    int stack[max],top=-1;
    int visited[n];
    for(int i=0;i<n;i++){
        visited[i]=0;
    }
    stack[++top]=start;
    visited[start]=1;
    printf("DFS Traversal: ");
    while(top!=-1){
        int v = stack[top--];
        if(visited[v]==0){
            printf("%d ",v);
            visited[v]=1;
        }
        for(int i=0;i<n;i++){
            if(graph[v][i]==1 && visited[i]==0){
                stack[++top]=i;
                visited[i]=1;
            }
        }
    }
    printf("\n");
}

int main(){
    int choice, u, v, start;

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    // initialize graph
    for(int i = 0; i < n; i++){
        for(int j = 0; j < n; j++){
            graph[i][j] = 0;
        }
    }

    while(1){
        printf("\n--- GRAPH MENU ---\n");
        printf("1. Insert Edge\n");
        printf("2. BFS Traversal\n");
        printf("3. DFS Traversal\n");
        printf("4. Exit\n");
        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch(choice){
            case 1:
                printf("Enter edge (u v): ");
                scanf("%d %d", &u, &v);
                if(u >= 0 && u < n && v >= 0 && v < n){
                    insert(u, v);
                } else {
                    printf("Invalid vertices!\n");
                }
                break;

            case 2:
                printf("Enter starting vertex for BFS: ");
                scanf("%d", &start);
                if(start >= 0 && start < n){
                    bfs(start);
                } else {
                    printf("Invalid start vertex!\n");
                }
                break;

            case 3:
                printf("Enter starting vertex for DFS: ");
                scanf("%d", &start);
                if(start >= 0 && start < n){
                    dfs(start);
                } else {
                    printf("Invalid start vertex!\n");
                }
                break;

            case 4:
                printf("Exiting...\n");
                exit(0);

            default:
                printf("Invalid choice! Try again.\n");
        }
    }

    return 0;
}
