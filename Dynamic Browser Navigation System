#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>
#define max 100
#define url_len 101

char forward[max][url_len];
char back[max][url_len];

int backwardtop=-1;
int forwardtop=-1;

char current[url_len] = "home.com";

int main() {
    int Q;
    scanf("%d",&Q);
    while(Q--){
        char command[10];
        scanf("%s",command);
        if(strcmp(command,"VISIT")==0){
            char url[url_len];
            scanf("%s",url);
            backwardtop++;
            strcpy(back[backwardtop],current);
            strcpy(current,url);
            forwardtop=-1;
        }
        else if(strcmp(command,"BACK")==0){
            if(backwardtop!=-1){
                forwardtop++;
                strcpy(forward[forwardtop],current);
                strcpy(current,back[backwardtop]);
                backwardtop--;
            }
            printf("%s\n",current);
        }
        else if(strcmp(command,"FORWARD")==0){
            if(forwardtop!=-1){
                backwardtop++;
                strcpy(back[backwardtop],current);
                strcpy(current,forward[forwardtop]);
                forwardtop--;
            }
            printf("%s\n",current);
        }
        else if(strcmp(command,"CURRENT")==0){
            printf("%s\n",current);
        }
    }
    return 0;
}
