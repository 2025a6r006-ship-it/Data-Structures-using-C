#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>
#include <limits.h>

int main() {
    int n;
    scanf("%d",&n);
    int tree[n];
    for(int i=0;i<n;i++){
        scanf("%d",&tree[i]);
    }
    int minval = tree[0];
    for(int i=1;i<n;i++){
        if(tree[i]<minval && tree[i]!=-1){
            minval = tree[i];
        }
    }
    printf("%d",minval);
    return 0;
}
