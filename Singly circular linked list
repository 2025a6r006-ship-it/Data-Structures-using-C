#include<stdio.h>
#include<stdlib.h>
struct Node{
    int data;
    struct Node* next;    // link between elements(logical).
};
struct Node* head = NULL;
struct Node* createNode(int data){
    struct Node* temp = (struct Node*)malloc(sizeof(struct Node));  // node created and address of node stored in temp.
    temp->data = data;  // stores data in node.
    temp->next = NULL;
    return temp;     // returns the address.
}
void insertinbeg(int data){
    struct Node* newNode = createNode(data);
    if(head==NULL){
        head = newNode;
        newNode->next = head;
    }
    else{
        struct Node* temp = head;
        while(temp->next!=head){
            temp = temp->next;
        }
        temp->next = newNode;
        newNode->next = head;
        head = newNode;
    }
    printf("Node Inserted in beginning\n");
}
void insertatend(int data){
    struct Node* newNode = createNode(data);
    if(head==NULL){
        head = newNode;
        newNode->next = head;
    }
    else{
        struct Node* temp = head;
        while(temp->next!=head){
            temp=temp->next;
        }
        temp->next = newNode;
        newNode->next = head;
    }
    printf("Node Inserted at End\n");
}
void insertatanypos(int data, int pos){   // here position is 0-base.
   if(head==NULL && pos==0){
        insertinbeg(data);
   }
   else if(pos==0){
      insertinbeg(data);
   }
   else{
        struct Node* temp = head;
        int i=0;
        while(i<pos-1){
            temp =temp->next;
            i++;
        }
        if(i!=pos-1){
            printf("Invalid Position\n");
        }
        else if(temp->next==head && i==pos-1){
            struct Node* newNode = createNode(data);
            insertatend(data);
        }
        else{
            struct Node* newNode = createNode(data);
            newNode->next = temp->next;
            temp->next = newNode;
        }
        printf("Node Inserted at given position\n");
   }
}
