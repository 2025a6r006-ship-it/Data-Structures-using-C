#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>
struct Node{
    int data;
    struct Node* right;
    struct Node* left;
};
struct Node* root = NULL;
struct Node* createNode(int data){
    struct Node* temp = (struct Node*)malloc(sizeof(struct Node));
    temp->data = data;
    temp->right = NULL;
    temp->left = NULL;
    return temp;
}

struct Node* insert(struct Node* root,int val){
    if(root==NULL){
        return createNode(val);
    }
    else if(val<root->data){
        root->left = insert(root->left,val);
    }
    else{
        root->right = insert(root->right,val);
    }
    return root;
}

void showTree(struct Node* root){
    if(root==NULL){
        return;
    }
    if(root->left==NULL && root->right==NULL){
        printf("%d ",root->data);
        return;
    }
    showTree(root->left);
    showTree(root->right);
}

int main() {
    int n;
    scanf("%d",&n);
    struct Node* root = NULL;
    for(int i=0;i<n;i++){
        int val;
        scanf("%d",&val);
        root = insert(root,val);
    }
    showTree(root);
    return 0;
}
