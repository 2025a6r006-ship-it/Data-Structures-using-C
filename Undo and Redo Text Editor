#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>
#define max 10000
char text[max];
int textlen=0;

char undostack[max];
int undotop=-1;

char redostack[max];
int redotop=-1;

int main() {
    int n;
    scanf("%d",&n);
    while(n--){
        int type;
        scanf("%d",&type);
        
        if(type==1){
            char c;
            scanf(" %c",&c);
            text[textlen++] = c;
            
            undostack[++undotop] = c;
            
            redotop = -1;
        }
        else if(type==2){
            if(undotop!=-1){
                char c = undostack[undotop--];
                textlen--;
                
                redostack[++redotop] = c;
            }
        }
        else if(type==3){
            if(redotop!=-1){
                char c = redostack[redotop--];
                text[textlen++] = c;
                
                undostack[++undotop] = c;
            }
        }
        else if(type==4){
            for(int i=0;i<textlen;i++){
                printf("%c",text[i]);
            }
            printf("\n");
        }
    }
    return 0;
}
