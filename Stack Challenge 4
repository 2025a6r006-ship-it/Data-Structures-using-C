#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>
int N1,N2,top1=-1,top2=-1;

void push_stack1(int *stack1, int value){
    if(top1==N1-1){
        printf("Overflow\n");
        return;
    }
    else{
        stack1[++top1]=value;
    }
}

void push_stack2(int *stack2, int value){
    if(top2==N2-1){
        printf("Overflow\n");
        return;
    }
    else{
        stack2[++top2]=value;
    }
}

void pop_stack1(int *stack1){
    if(top1==-1){
        printf("Underflow\n");
        return;
    }
    else{
        printf("%d\n",stack1[top1--]);
    }
}

void pop_stack2(int *stack2){
    if(top2==-1){
        printf("Underflow\n");
        return;
    }
    else{
        printf("%d\n",stack2[top2--]);
    }
}

void peek_stack1(int *stack1){
    if(top1==-1){
        printf("Underflow\n");
        return;
    }
    else{
        printf("%d\n",stack1[top1]);
    }
}

void peek_stack2(int *stack2){
    if(top2==-1){
        printf("Underflow\n");
        return;
    }
    printf("%d\n",stack2[top2]);
}

void display1(int *stack1){
    if(top1==-1){
        printf("Empty\n");
        return;
    }
    else{
        for(int i=top1;i>=0;i--){
            printf("%d",stack1[i]);
            if(i!=0)
                printf(" ");
        }
        printf("\n");
    }
}

void display2(int *stack2){
    if(top2==-1){
        printf("Empty\n");
        return;
    }
    else{
        for(int i=top2;i>=0;i--){
            printf("%d",stack2[i]);
            if(i!=0)
                printf(" ");
        }
        printf("\n");
    }
}

int main() {
    int Q;
    scanf("%d%d",&N1,&N2);
    scanf("%d",&Q);
    int stack1[N1],stack2[N2];
    
    while(Q--){
        char op[10];
        int s,data;
        
        scanf("%s",op);
        
        if(strcmp(op,"PUSH")==0){
            scanf("%d%d",&s,&data);
            if(s==1){
                push_stack1(stack1,data);
            }
            else{
                push_stack2(stack2,data);
            }
        }
        else if(strcmp(op,"POP")==0){
            scanf("%d",&s);
            if(s==1){
                pop_stack1(stack1);
            }
            else{
                pop_stack2(stack2);
            }
        }
        else if(strcmp(op,"PEEK")==0){
            scanf("%d",&s);
            if(s==1){
                peek_stack1(stack1);
            }
            else{
                peek_stack2(stack2);
            }
        }
        else if(strcmp(op,"DISPLAY")==0){
            scanf("%d",&s);
            if(s==1){
                display1(stack1);
            }
            else{
                display2(stack2);
            }
        }
    }
    return 0;
}
