#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() { 
    int MAX;
    scanf("%d",&MAX);
    int queue[MAX],front=-1,rear=-1;
    
void enqueue(int data){
    if(rear==MAX-1){
        printf("Queue Overflow\n");
        return;
    }
    queue[++rear] = data;
    if(front==-1){
        front = rear;
    }
}

int dequeue(){
    if(front==-1){
        printf("Queue Underflow\n");
        return -1;
    }
    int val = queue[front++];
    if(front>rear){
        front=-1;
        rear=-1;
    }
    return val;
}

int peek(){
    if(front==-1){
        printf("Queue Underflow\n");
        return -1;
    }
    return queue[front];
}

void display(){
    if(front==-1){
        printf("Queue is Empty\n");
        return;
    }
    else{
       for(int i=front;i<=rear;i++){
        printf("%d ",queue[i]);
       }
    }
    printf("\n");
}

    int choice,val,q;
    scanf("%d",&q);
    for(int i=0;i<q;i++){
        scanf("%d",&choice);
        switch(choice){
            case 1:
                scanf("%d",&val);
                enqueue(val);
                break;
            case 2:
                val = dequeue();
                if(val!=-1)
                    printf("%d\n",val);
                break;
            case 3:
                val = peek();
                if(val!=-1){
                    printf("%d\n",val);
                }
                break;
            case 4:
                display();
                break;
            default:
                printf("Invalid Choice\n");
                break;
        }
    }
    return 0;
}
