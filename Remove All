#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
    int n;
    scanf("%d",&n);
    
    int arr[n];
    for(int i=0;i<n;i++){
        scanf("%d",&arr[i]);
    }
    
    int x,k=0;
    scanf("%d",&x);
    for(int i=0;i<n;i++){
        if(arr[i]!=x){
            arr[k]=arr[i];
            k++;
        }
    }
    n=k;
    for(int i=0;i<n;i++){
        printf("%d ",arr[i]);
    }
    
    return 0;
}
